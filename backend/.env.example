ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/email_ops_clean

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ROUTING_HITL_CONFIDENCE_THRESHOLD=0.48
ROI_ASSUMED_MINUTES_PER_AUTO_CASE=5

EMAIL_INGEST_ENABLED=true
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_ID=me
GMAIL_POLL_QUERY=in:inbox is:unread -category:promotions
GMAIL_POLL_INTERVAL_SECONDS=20
GMAIL_MAX_MESSAGES_PER_POLL=5
GMAIL_MARK_AS_READ_AFTER_INGEST=true
GMAIL_INGEST_WATERMARK_ENABLED=true
GMAIL_RESET_INGEST_WATERMARK=false
GMAIL_INGEST_MAX_INTERNAL_AGE_SECONDS=0

HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=DEMO
JIRA_ISSUE_TYPE=Task

INTERNAL_API_KEY=dev-internal
ADMIN_API_KEY=dev-admin
